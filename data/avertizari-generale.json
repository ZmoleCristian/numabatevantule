      "mesaj": "<p align=\"center\"><span style=\"font-family: verdana, geneva; font-size: medium; color: #000000;\"><strong><span lang=\"RO\">ATENȚIONARE METEOROLOGICĂ<br /></span></strong></span><img src=\"../wp-content/plugins/meteo/admin/images/galben.gif\" alt=\"\" align=\"absmiddle\" /><span style=\"font-family: verdana, geneva; font-size: medium; color: #000000;\"><strong>COD GALBEN</strong></span></p>\r\n<p align=\"center\"><span style=\"font-family: verdana, geneva; font-size: small; color: #000000;\"><strong><span lang=\"RO\">Interval de valabilitate: 5 iulie, ora 12 &ndash; 5 iulie, ora 21<br /></span></strong><strong><span lang=\"RO\">Fenomene vizate: intensificări ale v&acirc;ntului<br /></span></strong><strong><span lang=\"RO\">Zone afectate: sudul Banatului, vestul și sud-vestul Olteniei</span></strong></span></p>\r\n<p style=\"text-align: justify;\" align=\"center\"><span style=\"font-family: verdana, geneva; font-size: small; color: #000000;\">&nbsp; &nbsp; &nbsp; &Icirc;n intervalul menționat, &icirc;n sudul Banatului și &icirc;n vestul și sud-vestul Olteniei vor fi intensificări ale v&acirc;ntului cu viteze de 50...70 km/h.</span></p>\r\n<p align=\"center\"><span style=\"font-family: verdana, geneva; font-size: small; color: #000000;\"><strong><em><span lang=\"RO\">&Icirc;n funcţie de evoluţia şi intensitatea fenomenelor meteorologice, Administraţia Naţională de Meteorologie va actualiza prezentul mesaj</span></em></strong><strong><em><span lang=\"RO\">.</span></em></strong></span></p>",
